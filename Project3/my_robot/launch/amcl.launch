<launch>
    
    <!-- Map Server -->
    <arg name="map_file" default="$(find my_robot)/maps/CartagenaMap.yaml"/>
    <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)"></node>
    
    <!-- AMCL Node -->
    <node name="amcl" pkg="amcl" type="amcl" output="screen">
       <!--<remap from="scan" to="my_robot/laser/scan"/>-->

       <param name="odom_frame_id" value="odom"/>
       <param name="odom_model_type" value="diff-corrected"/>
       <param name="base_frame_id" value="robot_footprint"/>
       <param name="global_frame_id" value="map"/>       
       
       <!-- Define initial pose -->
       <param name="initial_pose_x" value="0.0"/>
       <param name="initial_pose_y" value="0.0"/>
       
       <!-- Overall filter -->
       <param name="min_particles" value="80"/>
       <param name="max_particles" value="2000"/>
       
       <!-- Translational movement required before performing a filter update (meters)-->
       <param name="update_min_d" value="0.2"/>
       <!-- Rotational movement required before performing a filter update (radians) -->
       <param name="update_min_a" value="0.55"/> 
       
       <!-- Laser model parameters-->
       <param name="laser_model_type" value="likelihood_field"/>
       <param name="laser_max_beams" value="50"/>
    </node>
    
    <!-- Move Base -->
    <node name="move_base" pkg="move_base" type="move_base" respawn="false" output="screen">
       <remap from="scan" to="my_robot/laser/scan"/>
       <param name="base_global_planner" value="navfn/NavfnROS" />
       <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS"/>
       
       <rosparam file="$(find my_robot)/config/costmap_common_params.yaml" command="load" ns="global_costmap" />
       <rosparam file="$(find my_robot)/config/costmap_common_params.yaml" command="load" ns="local_costmap" />
       <rosparam file="$(find my_robot)/config/local_costmap_params.yaml" command="load" />       
       <rosparam file="$(find my_robot)/config/global_costmap_params.yaml" command="load" />
       <rosparam file="$(find my_robot)/config/base_local_planner_params.yaml" command="load" />
    </node>
</launch><launch>
    <arg name="map_file" default="$(find my_robot)/maps/CartagenaMap.yaml"/>
    
    <!-- Map Server -->
    <node name="map_server" pkg="map_server" type="map_server" args="$(arg map_file)"></node>
    
    <!-- AMCL Node -->
    <node name="amcl" pkg="amcl" type="amcl" output="screen">
       <remap from="scan" to="my_robot/laser/scan"/>
       <param name="global_frame_id" value="map"/>
       <param name="odom_frame_id" value="odom"/>
       <param name="odom_model_type" value="diff-corrected"/>
       <param name="base_frame_id" value="robot_footprint"/>
       <!--<param name="global_frame_id" value="map"/>-->
       
       <!-- If you choose to define initial pose here -->
       <param name="initial_pose_x" value="0.0"/>
       <param name="initial_pose_y" value="0.0"/>
    </node>
    
    <!-- Move Base -->
    <node name="move_base" pkg="move_base" type="move_base" respawn="false" output="screen">
       <remap from="scan" to="my_robot/laser/scan"/>
       <param name="base_global_planner" value="navfn/NavfnROS" />
       <param name="base_local_planner" value="base_local_planner/TrajectoryPlannerROS"/>
       
       <rosparam file="$(find my_robot)/config/costmap_common_params.yaml" command="load" ns="global_costmap" />
       <rosparam file="$(find my_robot)/config/costmap_common_params.yaml" command="load" ns="local_costmap" />
       <rosparam file="$(find my_robot)/config/local_costmap_params.yaml" command="load" />       
       <rosparam file="$(find my_robot)/config/global_costmap_params.yaml" command="load" />
       <rosparam file="$(find my_robot)/config/base_local_planner_params.yaml" command="load" />
    </node>
</launch>
